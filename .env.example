# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (Whisper for podcast audio transcription) ───────────────────────────
OPENAI_API_KEY=sk-...

# ── Tavily (web/news search) ────────────────────────────────────────────────────
# Sign up at https://tavily.com — free tier: 1,000 calls/month
TAVILY_API_KEY=tvly-...

# ── YouTube Data API v3 ─────────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com, enable "YouTube Data API v3"
YOUTUBE_API_KEY=AIza...

# ── Polygon.io (stock/ETF data) ─────────────────────────────────────────────────
# Free tier at https://polygon.io — sufficient for ticker validation
POLYGON_API_KEY=...

# ── Seeking Alpha (Playwright login) ────────────────────────────────────────────
# Your existing premium account credentials
SEEKING_ALPHA_EMAIL=you@example.com
SEEKING_ALPHA_PASSWORD=your_password_here
